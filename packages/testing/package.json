{
  "name": "@banzae/agent-runtime-testing",
  "version": "0.1.0-alpha.1",
  "description": "Conformance helpers for Banzae agent runtime adapters.",
  "license": "Apache-2.0",
  "author": "Banzae",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bazobazobazo/agent-runtime-sdk.git",
    "directory": "packages/testing"
  },
  "homepage": "https://github.com/bazobazobazo/agent-runtime-sdk#readme",
  "bugs": {
    "url": "https://github.com/bazobazobazo/agent-runtime-sdk/issues"
  },
  "keywords": [
    "agent",
    "runtime",
    "testing",
    "conformance",
    "typescript"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@banzae/agent-runtime-core": "workspace:0.1.0-alpha.1"
  },
  "peerDependencies": {
    "@banzae/agent-runtime-core": "workspace:0.1.0-alpha.1"
  }
}
