{
  "name": "@banzae/agent-runtime-openclaw",
  "version": "0.1.0",
  "description": "OpenClaw Gateway adapter for Banzae Agent Runtime SDK.",
  "license": "Apache-2.0",
  "engines": { "node": ">=22.13" },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./experimental": {
      "types": "./dist/experimental.d.ts",
      "import": "./dist/experimental.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@banzae/agent-runtime-core": "workspace:*"
  },
  "peerDependencies": {
    "@banzae/agent-runtime-core": "^0.1.0"
  }
}
