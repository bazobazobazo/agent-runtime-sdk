{
  "name": "@banzae/agent-runtime-hermes",
  "version": "0.1.0",
  "description": "Hermes Agent HTTP/SSE adapter for Banzae Agent Runtime SDK.",
  "license": "Apache-2.0",
  "author": "Banzae",
  "repository": { "type": "git", "url": "git+https://github.com/bazobazobazo/agent-runtime-sdk.git", "directory": "packages/adapter-hermes" },
  "homepage": "https://github.com/bazobazobazo/agent-runtime-sdk#readme",
  "bugs": { "url": "https://github.com/bazobazobazo/agent-runtime-sdk/issues" },
  "keywords": ["agent", "runtime", "hermes", "sse", "typescript"],
  "engines": { "node": ">=22.13" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./experimental": {
      "types": "./dist/experimental.d.ts",
      "import": "./dist/experimental.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "THIRD_PARTY_NOTICES.md"],
  "publishConfig": { "access": "public", "provenance": true },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@banzae/agent-runtime-core": "workspace:0.1.0"
  },
  "peerDependencies": {
    "@banzae/agent-runtime-core": "workspace:0.1.0"
  }
}
