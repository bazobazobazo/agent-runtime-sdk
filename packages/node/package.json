{
  "name": "@banzae/agent-runtime-node",
  "version": "0.1.0-alpha.2",
  "description": "Node.js facade and default implementations for Banzae Agent Runtime SDK.",
  "license": "Apache-2.0",
  "author": "Banzae",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bazobazobazo/agent-runtime-sdk.git",
    "directory": "packages/node"
  },
  "homepage": "https://github.com/bazobazobazo/agent-runtime-sdk#readme",
  "bugs": {
    "url": "https://github.com/bazobazobazo/agent-runtime-sdk/issues"
  },
  "keywords": [
    "agent",
    "runtime",
    "node",
    "typescript",
    "sdk"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@banzae/agent-runtime-core": "workspace:0.1.0-alpha.2",
    "@banzae/agent-runtime-detection": "workspace:0.1.0-alpha.2",
    "@banzae/agent-runtime-hermes": "workspace:0.1.0-alpha.2",
    "@banzae/agent-runtime-openclaw": "workspace:0.1.0-alpha.2",
    "ws": "^8.18.3"
  }
}
