  },
  "dependencies": {
    "@banzae/agent-runtime-core": "workspace:*",
    "@banzae/agent-runtime-detection": "workspace:*",
    "@banzae/agent-runtime-hermes": "workspace:*",
    "@banzae/agent-runtime-openclaw": "workspace:*",
    "ws": "^8.18.3"
  }
