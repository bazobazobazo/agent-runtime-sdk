{
  "name": "@banzae/agent-runtime-detection",
  "version": "0.1.0",
  "description": "Safe runtime detection for Banzae agent runtimes.",
  "license": "Apache-2.0",
  "engines": { "node": ">=22.13" },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@banzae/agent-runtime-core": "workspace:*",
    "@banzae/agent-runtime-openclaw": "workspace:*"
  }
}
