{
  "name": "@banzae/agent-runtime-core",
  "version": "0.1.0-alpha.2",
  "description": "Provider-neutral contracts for Banzae agent runtime adapters.",
  "license": "Apache-2.0",
  "author": "Banzae",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bazobazobazo/agent-runtime-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/bazobazobazo/agent-runtime-sdk#readme",
  "bugs": {
    "url": "https://github.com/bazobazobazo/agent-runtime-sdk/issues"
  },
  "keywords": [
    "agent",
    "runtime",
    "sdk",
    "typescript",
    "provider-neutral"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./experimental": {
      "types": "./dist/experimental.d.ts",
      "import": "./dist/experimental.js"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics.d.ts",
      "import": "./dist/diagnostics.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
