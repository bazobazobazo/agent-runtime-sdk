{
  "schemaVersion": 1,
  "sdkVersion": "0.1.0-alpha.1",
  "sourceVersion": "0.1.0-alpha.1",
  "distTags": {
    "prerelease": "next",
    "stable": "latest"
  },
  "artifactDirectory": "artifacts/release",
  "publicPackages": [
    "@banzae/agent-runtime-core",
    "@banzae/agent-runtime-detection",
    "@banzae/agent-runtime-openclaw",
    "@banzae/agent-runtime-hermes",
    "@banzae/agent-runtime-testing",
    "@banzae/agent-runtime-node"
  ],
  "privatePackages": [
    "@banzae/agent-runtime-codex-placeholder",
    "@banzae/agent-runtime-pi-placeholder",
    "@banzae/agent-runtime-adapter-template"
