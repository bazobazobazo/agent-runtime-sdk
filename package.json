{
  "name": "agent-runtime-sdk",
  "private": true,
  "version": "0.0.0",
  "description": "Banzae provider-neutral agent runtime SDK monorepo.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "clean": "pnpm -r --filter './packages/*' run clean",
    "typecheck": "tsc -b packages/*/tsconfig.json",
    "test": "vitest run",
    "test:core": "pnpm --filter @banzae/agent-runtime-core test",
    "test:detection": "pnpm --filter @banzae/agent-runtime-detection test",
    "test:openclaw:v3": "vitest run packages/testing/src/openclaw-v3-conformance.test.ts",
    "test:openclaw:v4": "vitest run packages/testing/src/openclaw-v4-conformance.test.ts",
    "test:hermes": "vitest run packages/adapter-hermes/src/hermes.test.ts packages/testing/src/hermes-conformance.test.ts",
    "test:conformance": "vitest run packages/testing/src/*-conformance.test.ts",
    "test:live": "vitest run packages/testing/src/live-compatibility.test.ts packages/testing/src/live-fake-runtime.test.ts",
    "test:live:cli": "node ./scripts/test-live-cli.mjs",
    "test:fuzz": "FUZZ_RUNS=100 FUZZ_SEED=20260714 vitest run packages/testing/src/security-fuzz.test.ts",
    "test:fuzz:extended": "FUZZ_RUNS=5000 FUZZ_SEED=20260714 vitest run packages/testing/src/security-fuzz.test.ts",
    "test:resilience": "vitest run packages/testing/src/security-resilience.test.ts",
    "lint": "tsc -b packages/*/tsconfig.json --pretty false",
    "api:snapshot": "UPDATE_API_SNAPSHOT=1 node ./scripts/check-api-snapshot.mjs",
    "api:extract": "node ./scripts/extract-public-api.mjs --write",
    "api:check": "node ./scripts/extract-public-api.mjs",
    "package:check": "node ./scripts/check-package-boundaries.mjs",
    "package:contents": "node ./scripts/check-package-contents.mjs",
    "consumer:check": "node ./scripts/test-packed-consumer.mjs",
    "examples:typecheck": "tsc -p examples/tsconfig.json --noEmit",
    "examples:test": "vitest run --config examples/vitest.config.ts",
    "docs:check": "node ./scripts/check-docs.mjs",
    "unicode:check": "node ./scripts/check-unicode.mjs",
    "secret:scan": "node ./scripts/secret-scan.mjs",
    "fixture:check": "node ./scripts/validate-fixtures.mjs",
    "artifact:scan": "node ./scripts/scan-build-artifacts.mjs",
    "license:check": "node ./scripts/check-licenses.mjs",
    "dependency:check": "node ./scripts/dependency-check.mjs",
    "workflow:security": "node ./scripts/check-workflow-security.mjs",
    "test:security:scripts": "node ./scripts/test-security-scripts.mjs",
    "dependency:audit": "pnpm audit --prod --audit-level high",
    "security:check": "pnpm fixture:check && pnpm test:security:scripts && pnpm workflow:security && pnpm license:check && pnpm secret:scan && pnpm unicode:check",
    "changeset": "changeset",
    "version:check": "node ./scripts/version-check.mjs",
    "version:apply": "node ./scripts/apply-release-plan.mjs",
    "version:preview": "node ./scripts/release-plan.mjs",
    "release:plan": "node ./scripts/release-plan.mjs --json",
    "artifacts:pack": "node ./scripts/prepare-release-packages.mjs",
    "artifacts:manifest": "node ./scripts/generate-release-manifest.mjs",
    "artifacts:checksums": "node ./scripts/generate-release-manifest.mjs",
    "artifacts:check": "node ./scripts/validate-release-artifacts.mjs",
    "sbom:generate": "node ./scripts/generate-sbom.mjs",
    "provenance:check": "node ./scripts/provenance-check.mjs",
    "build:reproducibility-check": "node ./scripts/check-build-reproducibility.mjs",
    "release:test": "node ./scripts/test-release-engineering.mjs",
    "release:dry-run": "node ./scripts/release-dry-run.mjs",
    "release:gate": "node ./scripts/release-gate.mjs",
    "fixtures:capture:openclaw": "node ./scripts/capture-openclaw-fixtures.mjs",
    "fixtures:capture:hermes": "node ./scripts/capture-hermes-fixtures.mjs",
    "live:openclaw": "node ./scripts/live-compatibility.mjs openclaw",
    "live:hermes": "node ./scripts/live-compatibility.mjs hermes",
    "live:compatibility": "node ./scripts/live-compatibility.mjs both",
    "live:fixtures": "node ./scripts/live-fixtures.mjs",
    "live:compare": "node ./scripts/live-compare.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^24.7.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "fast-check": "^4.9.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "ws": "^8.18.3"
  }
}
